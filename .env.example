APP_NAME="UM Visayan Clinic"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database ─────────────────────────────────────────
# For Docker: DB_HOST=db  |  For local: DB_HOST=127.0.0.1
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=clinic_db
DB_USERNAME=root
DB_PASSWORD=

# ── Mail (Gmail SMTP) ─────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your_gmail@gmail.com
MAIL_FROM_NAME="UM Visayan Clinic"

# ── Session ───────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false

# ── Cache ─────────────────────────────────────────────
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
